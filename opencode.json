{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "grep": "allow",
        "glob": "allow"
      }
    },
    "plan": {
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "explore-docs": {
      "description": "Trace the document upload → summary → wiki pipeline end-to-end",
      "mode": "subagent",
      "temperature": 0.1,
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "edit": "deny"
      }
    },
    "flow-architect": {
      "description": "Maps system architecture, data flow, and identifies root causes of bugs",
      "mode": "subagent",
      "temperature": 0.1,
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "edit": "deny"
      }
    }
  },
  "rule": {
    "files": [".opencode/rules.md"]
  }
}
