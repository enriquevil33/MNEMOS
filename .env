# MNEMOS — Configuración para SISS / MOMO-MAIN
# Mac local, sin Docker propio, usa momo-postgres y valkey existentes

# App
SECRET_KEY=mnemos_siss_2026_local

# Base de datos — momo-postgres existente (puerto 5433)
DATABASE_URL=postgresql://momo:momo_local_2026@localhost:5433/mnemos_db

# Redis — valkey existente (puerto 6380)
REDIS_URL=redis://localhost:6380/0

# LLM — Ollama local
LLM_PROVIDER=ollama
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=qwen3.5:9b
OLLAMA_BASE_URL=http://localhost:11434/v1

# Embeddings — bge-m3 via Ollama (multilingüe, perfecto para español DOF)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=cpu
EMBEDDING_USE_FP16=false
EMBEDDING_BATCH_SIZE=8

# Whisper (transcripción audio — no prioritario para NOMs)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# Memoria persistente
MEMORY_ENABLED=true
MEMORY_PROVIDER=ollama

# Búsqueda web
WEB_SEARCH_PROVIDER=duckduckgo

# Hypergraph — mismo LLM que chat
HYPERGRAPH_LLM_PROVIDER=

# Rutas locales (Mac, no Docker)
UPLOAD_FOLDER=/Users/enrique/MOMO-MAIN/LOCAL_SISTEMA/mnemos/data/uploads
ARCHIVE_FOLDER=/Users/enrique/MOMO-MAIN/LOCAL_SISTEMA/mnemos/data/archive

# Flask
FLASK_ENV=development
RUN_MIGRATIONS=true
